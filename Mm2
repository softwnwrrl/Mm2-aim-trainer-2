-- Поиск remote для выстрела
local function updateRemote()
    local potential = game:GetService("ReplicatedStorage"):FindFirstChild("ShootStart", true) 
                   or workspace:FindFirstChild("ShootStart", true)
    if potential then shootRemote = potential end
end

-- Получение пистолета
local function getGun()
    local backpack = player:FindFirstChild("Backpack")
    local char = character
    if not backpack or not char then return nil end
    local tool = char:FindFirstChildOfClass("Tool")
    if tool and (tool.Name:lower():find("gun") or tool:FindFirstChild("GunServer")) then return tool end
    for _, v in pairs(backpack:GetChildren()) do
        if v:IsA("Tool") and (v.Name:lower():find("gun") or v:FindFirstChild("GunServer")) then return v end
    end
    return nil
end

-- Луч (Beam) из источника
local beam = Instance.new("Beam")
beam.FaceCamera = true
beam.Width0 = 0.2
beam.Width1 = 0.2
beam.Color = ColorSequence.new(Color3.fromRGB(255, 0, 0))
beam.Transparency = NumberSequence.new(0.5)
beam.Enabled = false
beam.Parent = workspace.Terrain

local attach0 = Instance.new("Attachment")
local attach1 = Instance.new("Attachment")
beam.Attachment0 = attach0
beam.Attachment1 = attach1

local function updateBeam(predictedPos)
    local char = character
    local gun = getGun()
    local rightArm = char and (char:FindFirstChild("Right Arm") or char:FindFirstChild("RightHand"))

    if showBeam and silentAimEnabled and gun and predictedPos and rightArm then
        attach0.Parent = rightArm
        attach0.Position = Vector3.new(1.2, 0.5, 0)
        attach1.Parent = workspace.Terrain
        attach1.WorldPosition = predictedPos
        beam.Enabled = true
    else
        beam.Enabled = false
    end
end

-- WallCheck (из источника)
local function canSeeAdvanced(target)
    if not wallCheck then return true end
    if not target or not target:FindFirstChild("HumanoidRootPart") then return false end
    local char = character
    if not char:FindFirstChild("Head") then return false end

    local origin = char.Head.Position
    local destination = target.HumanoidRootPart.Position
    local direction = destination - origin

    local params = RaycastParams.new()
    local ignoreList = {char, target}
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and obj ~= target and obj:FindFirstChild("Humanoid") then
            table.insert(ignoreList, obj)
        end
    end
    params.FilterDescendantsInstances = ignoreList
    params.FilterType = Enum.RaycastFilterType.Exclude

    local result = workspace:Raycast(origin, direction, params)
    return not result or result.Instance.Transparency > 0.7 or result.Instance.CanCollide == false
end

-- Предсказание позиции (из источника)
local function getPredictedPosition(target)
    local hrp = target:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end

    local pos = hrp.Position
    local rawVel = hrp.Velocity

    if not velocitySmooth[target] then velocitySmooth[target] = rawVel end
    local smoothVel = velocitySmooth[target]:Lerp(rawVel, smoothFactor)
    velocitySmooth[target] = smoothVel

    local ping = settings().Network.IncomingReplicationLag
    local t = ping + predictDelay

    return pos + smoothVel * t * velocityMult
end

-- Выстрел (из источника)
local function performShot(pos)
    local gun = getGun()
    if not gun then return end
    local char = character

    if autoEquip and gun.Parent == player.Backpack then
        humanoid:EquipTool(gun)
        task.wait(0.01)
        updateRemote()
        if shootRemote then shootRemote:FireServer(pos) end
        task.wait(0.04)
        humanoid:UnequipTools()
    else
        updateRemote()
        if shootRemote then shootRemote:FireServer(pos) end
    end
end

-- ============ ПОЛУЧЕНИЕ БОТОВ ============
local function getBots()
    local bots = {}
    local playerChar = character
    if not playerChar then return bots end
    
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and obj ~= playerChar then
            local hum = obj:FindFirstChildWhichIsA("Humanoid")
            if hum and hum.Health > 0 then
                local root = obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChild("Torso")
                if root then
                    table.insert(bots, {
                        model = obj,
                        humanoid = hum,
                        rootPart = root,
                        head = obj:FindFirstChild("Head"),
                        originalCF = root.CFrame
                    })
                end
            end
        end
    end
    return bots
end

-- ============ АВТОСТАРТ ============
local function autoStartRound()
    local startButton = nil
    for _, gui in ipairs(player.PlayerGui:GetChildren()) do
        if gui:IsA("ScreenGui") then
            startButton = gui:FindFirstChild("StartButton") or
                          gui:FindFirstChild("PlayButton") or
                          gui:FindFirstChild("RespawnButton") or
                          gui:FindFirstChild("SkipButton")
            if startButton and startButton:IsA("TextButton") then
                break
            end
        end
    end
    if not startButton then
        for _, gui in ipairs(game:GetService("CoreGui"):GetChildren()) do
            startButton = gui:FindFirstChild("StartButton") or gui:FindFirstChild("PlayButton")
            if startButton and startButton:IsA("TextButton") then
                break
            end
        end
    end
    if startButton then
        startButton:Click()
        return true
    end
    local remote = game:GetService("ReplicatedStorage"):FindFirstChild("StartRound") or
                   game:GetService("ReplicatedStorage"):FindFirstChild("StartGame")
    if remote then
        pcall(function() remote:FireServer() end)
        return true
    end
    return false
end

task.spawn(function()
    while true do
        task.wait(5)
        if autoStartEnabled then
            autoStartRound()
        end
    end
end)

-- ============ ESP (HIGHLIGHT ИЗ ИСТОЧНИКА) ============
local highlight = Instance.new("Highlight")
highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop

local function updateESP()
    if not espEnabled or not currentTarget then
        highlight.Parent = nil
        return
    end
    local visible = canSeeAdvanced(currentTarget)
    highlight.Parent = currentTarget
    highlight.FillColor = visible and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(255, 0, 0)
end

-- ============ ОСНОВНОЙ ЦИКЛ (ВЫБОР ЦЕЛИ) ============
RunService.Heartbeat:Connect(function()
    if not silentAimEnabled then 
        highlight.Parent = nil
        beam.Enabled = false
        return 
    end
    
    local closest, minDist = nil, 2000
    local myRoot = rootPart
    if not myRoot then return end

    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("Humanoid") then
            local char = obj.Parent
            if char and char ~= character then
                local hum = obj
                local hrp = char:FindFirstChild("HumanoidRootPart")
                if hum.Health > 0 and hrp then
                    local dist = (myRoot.Position - hrp.Position).Magnitude
                    if dist < minDist then
                        minDist = dist
                        closest = char
                    end
                end
            end
        end
    end

    currentTarget = closest

    for target, _ in pairs(velocitySmooth) do
        if target ~= currentTarget then
            velocitySmooth[target] = nil
        end
    end

    if currentTarget then
        local aimPos = getPredictedPosition(currentTarget)
        if aimPos then
            updateBeam(aimPos)
            
            if autoShoot and canSeeAdvanced(currentTarget) and tick() - lastShootTime > 0.73 then
                performShot(aimPos)
                lastShootTime = tick()
            end
        end
    else
        beam.Enabled = false
    end
    
    updateESP()
end)

