-- ============ AUTOWALK FARM ============
local function getClosestBotForWalk()
    local bots = getBots()
    if #bots == 0 then return nil end
    local playerPos = rootPart and rootPart.Position or Vector3.zero
    local closest = nil
    local closestDist = math.huge
    for _, bot in ipairs(bots) do
        local botPos = bot.rootPart and bot.rootPart.Position
        if botPos then
            local dist = (playerPos - botPos).Magnitude
            if dist < closestDist and dist <= walkRange then
                closestDist = dist
                closest = bot.model
            end
        end
    end
    return closest
end

local function setNoclip(state)
    for _, part in ipairs(character:GetDescendants()) do
        if part:IsA("BasePart") then
            part.CanCollide = not state
        end
    end
end

local function walkFarmCycle()
    if not autoFarmEnabled or farmMode ~= "Walk" then return end
    if not character or not character.Parent then return end
    
    local closest = getClosestBotForWalk()
    if closest and closest:FindFirstChild("HumanoidRootPart") then
        local targetPos = closest.HumanoidRootPart.Position
        local dist = (rootPart.Position - targetPos).Magnitude
        
        humanoid:MoveTo(targetPos)
        humanoid.WalkSpeed = walkSpeed
        setNoclip(true)
        
        if dist < 15 and autoShoot then
            local aimPos = getPredictedPosition(closest)
            if aimPos then performShot(aimPos) end
        end
    else
        humanoid.WalkSpeed = 16
        setNoclip(false)
    end
end

-- ============ AUTOTP FARM ============
local function getRandomBot()
    local bots = getBots()
    if #bots == 0 then return nil end
    return bots[math.random(1, #bots)]
end

local function startTpFarm()
    if tpFarmConnection then coroutine.close(tpFarmConnection) end
    tpFarmConnection = task.spawn(function()
        while autoFarmEnabled and farmMode == "TP" do
            if not isTpActive then
                isTpActive = true
                local targetBot = getRandomBot()
                if targetBot and targetBot.model then
                    targetBot.originalCF = targetBot.rootPart.CFrame
                    local facePos = (rootPart.CFrame * CFrame.new(0, 0, -5)).Position
                    targetBot.rootPart.CFrame = CFrame.new(facePos)
                    task.wait(tpVisibleTime)
                    if targetBot.rootPart then
                        targetBot.rootPart.CFrame = targetBot.originalCF
                    end
                    if autoShoot then
                        local aimPos = getPredictedPosition(targetBot.model)
                        if aimPos then performShot(aimPos) end
                    end
                end
                isTpActive = false
            end
            task.wait(tpCooldown)
        end
    end)
end

-- ============ ЗАПУСК ФАРМА ============
local function startFarm()
    if farmConnection then farmConnection:Disconnect() end
    if tpFarmConnection then coroutine.close(tpFarmConnection) end
    
    if farmMode == "Walk" then
        farmConnection = RunService.RenderStepped:Connect(walkFarmCycle)
    else
        startTpFarm()
    end
end

local function stopFarm()
    if farmConnection then
        farmConnection:Disconnect()
        farmConnection = nil
    end
    if tpFarmConnection then
        coroutine.close(tpFarmConnection)
        tpFarmConnection = nil
    end
    humanoid.WalkSpeed = 16
    setNoclip(false)
    isTpActive = false
end

